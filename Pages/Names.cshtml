@page
@model MyWebApp.Pages.NamesModel
@{
    ViewData["Title"] = "Names";
}

<h1>Names</h1>

<table class="table">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
        </tr>
    </thead>
    <tbody>
    @for (int i = 0; i < Model.Names.Count; i++)
    {
        <tr>
            <td>@(i + 1)</td>
            <td>@Model.Names[i]</td>
        </tr>
    }
    </tbody>
</table>