# .dockerignore file to exclude unnecessary files from Docker build context

# Build outputs
bin/
obj/
publish/

# IDE files
.vs/
.vscode/
.idea/
*.swp
*.swo
*~

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Git
.git/
.gitignore
.gitattributes

# Azure DevOps
azure-pipelines*.yml
*.md
AZURE_DEVOPS_SETUP.md
QUICK_START.md

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Test files (optional - include if you want to exclude tests)
# **/*Tests/
# **/*.Tests/

# Node modules (if any)
node_modules/

# Temporary files
*.tmp
*.temp
*.log

